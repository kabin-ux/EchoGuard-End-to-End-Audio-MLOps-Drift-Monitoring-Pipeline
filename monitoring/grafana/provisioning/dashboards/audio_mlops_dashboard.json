{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Real-time monitoring for the Audio Genre Classification ML pipeline — latency, throughput, drift signals, and per-genre prediction distribution.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Predictions",
      "description": "Cumulative number of genre classifications served.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "orange", "value": 10000 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum(audio_predictions_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Prediction Rate (last 5 m)",
      "description": "Predictions per second averaged over 5 minutes.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "reqps",
          "decimals": 3
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum(rate(audio_predictions_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency",
      "description": "95th-percentile end-to-end prediction latency.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red", "value": 3.0 }
            ]
          },
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Drift P-Value (min)",
      "description": "Minimum KS p-value across all features. Values below 0.05 indicate potential drift.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "green", "value": 0.05 }
            ]
          },
          "unit": "none",
          "decimals": 4,
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "feature_drift_p_value",
          "legendFormat": "p-value",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Drift Window Size",
      "description": "Number of samples currently in the drift detection rolling window.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "drift_window_size",
          "legendFormat": "samples",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Prediction Latency Distribution",
      "description": "P50, P95, and P99 prediction latencies over time.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.50, sum(rate(prediction_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.99, sum(rate(prediction_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Feature Drift P-Value Over Time",
      "description": "KS test minimum p-value. Sustained dips below 0.05 indicate data drift.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "green", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "feature_drift_p_value",
          "legendFormat": "Min KS p-value",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Predictions by Genre (rate/5m)",
      "description": "Per-genre prediction rate over time.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum by (genre) (rate(audio_predictions_total[5m]))",
          "legendFormat": "{{genre}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Upload File Size Distribution (P50, P95)",
      "description": "Audio file size percentiles — helps detect format / quality changes.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.50, sum(rate(audio_upload_bytes_bucket[5m])) by (le))",
          "legendFormat": "P50 upload size",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.95, sum(rate(audio_upload_bytes_bucket[5m])) by (le))",
          "legendFormat": "P95 upload size",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["mlops", "audio", "genre-classification", "drift-monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Audio Genre Classification — MLOps Dashboard",
  "uid": "audio-genre-mlops",
  "version": 1
}
